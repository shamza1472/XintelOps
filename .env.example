# XIntelOps — Cursor-Native Configuration
#
# PRODUCTION: Use Cursor Cloud Agent secrets (see docs/CURSOR_AUTOMATION.md)
# Do NOT add OpenAI or Anthropic keys unless using legacy API mode.
#
# LOCAL DEV ONLY: copy to .env

# LLM mode: cursor (default, no API cost) | anthropic (legacy external APIs)
LLM_PROVIDER=cursor

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LLM APIs (only required when LLM_PROVIDER=anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email (Resend)
RESEND_API_KEY=re_...
RECIPIENT_EMAIL=you@example.com

# Pipeline settings
SIMILARITY_THRESHOLD=0.85
RATE_DELAY_MS=3000
FETCH_TIMEOUT_SEC=12
MAX_CHARS_PER_SOURCE=2000
JOURNALIST_BATCH_SIZE=10

# Paths (relative to repo root)
SOURCES_CSV_PATH=data/xintel_sources.csv
JOURNALISTS_CSV_PATH=data/journalists.csv

# Optional: syndication base for X profile RSS (no paid X API required)
TWITTER_RSS_BASE=https://rsshub.app/twitter/user

# Dual-write to legacy production tables during transition
DUAL_WRITE_LEGACY=true
