# XIntelOps Configuration File
# Copy this to .env and fill in your actual values

# ===== File Paths =====
SOURCES_CSV_PATH=/Users/sheikhhamza/Desktop/XintelOps/data/sources.csv

# ===== MySQL Database Configuration =====
# MySQL connection details for XIntelOps database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=xintelops
MYSQL_USER=xintelops_user
MYSQL_PASSWORD=your_mysql_password

# ===== Telegram Configuration =====
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz

# Get chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# ===== OpenAI Configuration =====
# Get API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set to "true" to use OpenAI for draft generation
# Set to "false" to use template-based fallback
LLM_ENABLED=true

# ===== Scraping Configuration =====
# Number of sources to process in each batch
BATCH_SIZE=5

# Delay between HTTP requests (milliseconds) to avoid rate limiting
RATE_DELAY_MS=3000

# ===== Post Configuration =====
# Maximum character limit for X (Twitter) posts
POST_CHAR_LIMIT_X=280

# Maximum character limit for LinkedIn posts
POST_CHAR_LIMIT_LI=1200

# ===== Security =====
# Secret key for webhook authentication
# Change this to a random secure string
APPROVAL_SECRET=change_me_to_random_secure_string

# Base URL where n8n is hosted (for webhook callbacks)
BASE_URL=https://your-n8n-instance.com

# ===== Optional: Advanced Settings =====
# Minimum score threshold for content to be drafted (0-100)
MIN_SCORE_THRESHOLD=60

# SQLite database file location
# DB_PATH=/Users/sheikhhamza/Desktop/XintelOps/data/xintelops.sqlite

